{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "blly.to"
        }
      ],
      "headers": {
        "Location": "https://portal.blly.to"
      },
      "status": 301
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}